# Production environment — copy to /opt/monitoring-app/.env on EC2
# Values marked SECRET must be set in GitHub Secrets, not here

GITHUB_REPOSITORY=alhailrose/monitoring-ics-apps
IMAGE_TAG=latest

# SECRET — set in GitHub Secrets
DATABASE_URL=postgresql+psycopg://superadmin:PASSWORD@10.0.10.11:5432/ics_ms_monitoringapps

# SECRET — generate with: openssl rand -hex 32
JWT_SECRET=

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=

# Gmail SMTP (use App Password from myaccount.google.com/apppasswords)
SMTP_USER=msmonitoring@icscompute.com
SMTP_PASSWORD=
SMTP_FROM=ICS Monitoring Hub <msmonitoring@icscompute.com>
APP_BASE_URL=https://msmonitoring.bagusganteng.app

DEFAULT_REGION=ap-southeast-3
MAX_WORKERS=5
EXECUTION_TIMEOUT=300
CORS_ORIGINS=*
API_AUTH_ENABLED=true
NEXT_PUBLIC_API_URL=/api
# Domain: https://msmonitoring.bagusganteng.app
CORS_ORIGINS=https://msmonitoring.bagusganteng.app
